{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/stories/:slug", "destination": "/api/og/:slug" },
    { "source": "/stories", "destination": "/?view=library" },
    { "source": "/nightcard/:token", "destination": "/api/og-nightcard/:token" },
    { "source": "/sitemap.xml", "destination": "/api/sitemap" }
  ],
  "functions": {
    "api/claude.js":  { "maxDuration": 60 },
    "api/tts.js":     { "maxDuration": 30 },
    "api/clone.js":   { "maxDuration": 30 },
    "api/health.js":      { "maxDuration": 10 },
    "api/book-of-day.js": { "maxDuration": 60 },
    "api/story-journeys/start.js":          { "maxDuration": 60 },
    "api/story-journeys/[id]/index.js":     { "maxDuration": 30 },
    "api/story-journeys/[id]/read.js":      { "maxDuration": 120 },
    "api/story-journeys/[id]/complete.js":  { "maxDuration": 120 },
    "api/story-journeys/[id]/summary.js":   { "maxDuration": 30 },
    "api/story-series/start-from-book.js":  { "maxDuration": 30 },
    "api/remix.js":                         { "maxDuration": 60 },
    "api/og/[slug].js":                     { "maxDuration": 10 },
    "api/og-image/[slug].js":               { "maxDuration": 10 },
    "api/og-nightcard/[token].js":          { "maxDuration": 10 },
    "api/og-nightcard-image/[token].js":    { "maxDuration": 10 }
  },
  "crons": [{
    "path": "/api/book-of-day",
    "schedule": "0 6 * * *"
  }],
  "headers": [
    {
      "source": "/sw.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Service-Worker-Allowed", "value": "/" }
      ]
    },
    {
      "source": "/manifest.json",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache" }
      ]
    }
  ]
}
