# Copy this file to .env.local for local development
# Never commit .env.local to git

# Your Anthropic API key — from console.anthropic.com
ANTHROPIC_KEY=your_anthropic_key_here

# Your ElevenLabs API key — from elevenlabs.io/app/settings/api-keys
ELEVENLABS_KEY=your_elevenlabs_key_here

# Your cloned voice ID from elevenlabs.io (used server-side for TTS)
ELEVENLABS_VOICE_ID=your_voice_id_here

# Same voice ID — this one is injected into the frontend at build time
VITE_NARRATOR_VOICE_ID=your_voice_id_here
